<?xml version="1.0" encoding="utf-8"?>
<!-- item_ayah.xml — Matches Fan Quran website ayah layout exactly -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:paddingLeft="20dp"
    android:paddingRight="0dp"
    android:paddingTop="20dp"
    android:paddingBottom="20dp">

    <!-- Row: Nomor ayat (kiri) + Teks Arab (kanan) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Nomor Ayat (lingkaran putih, PERSIS seperti website) -->
        <TextView
            android:id="@+id/tv_ayah_number"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:background="@drawable/circle_bg"
            android:textColor="@color/number_circle_text"
            android:textSize="13sp"
            android:textStyle="bold"
            android:text="1" />

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Teks Arab + garis hijau kanan (seperti website) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_ayah_arabic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="بِسْمِ اللّٰهِ الرَّحْمٰنِ الرَّحِيْمِ"
                android:textSize="22sp"
                android:textColor="@color/text_arabic"
                android:gravity="end"
                android:fontFamily="serif"
                android:lineSpacingExtra="6dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Latin transliterasi -->
    <TextView
        android:id="@+id/tv_ayah_latin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bismillāhir-rahmānir-rahīm(i)."
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/text_latin"
        android:layout_marginTop="14dp"
        android:layout_marginRight="24dp" />

    <!-- Terjemahan Indonesia -->
    <TextView
        android:id="@+id/tv_ayah_translation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Dengan nama Allah Yang Maha Pengasih, Maha Penyayang."
        android:textSize="14sp"
        android:textColor="@color/text_latin"
        android:lineSpacingExtra="4dp"
        android:layout_marginTop="4dp"
        android:layout_marginRight="24dp" />

    <!-- Divider bawah -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginTop="20dp"
        android:layout_marginRight="24dp" />

</LinearLayout>
